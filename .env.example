# ──────────────────────────────────────────────────────────────
# JDE AIS Connection
# ──────────────────────────────────────────────────────────────
JDE_AIS_URL=https://your-ais-server:port/jderest
JDE_USERNAME=your_jde_user
JDE_PASSWORD=your_jde_password
JDE_ENVIRONMENT=JDV920
JDE_ROLE=*ALL

# ──────────────────────────────────────────────────────────────
# MCP Server Transport
# ──────────────────────────────────────────────────────────────
# "stdio" for Claude Desktop / Claude Code (default)
# "http"  for remote / multi-client deployment
TRANSPORT=stdio

# Port for HTTP transport (ignored for stdio)
PORT=3000
