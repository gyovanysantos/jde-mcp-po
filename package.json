{
  "name": "jde-mcp-po-server",
  "version": "1.0.0",
  "description": "MCP server for JD Edwards EnterpriseOne AIS integration — Purchase Order CRUD tools",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npx shx cp -r src/data dist/data",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run build",
    "test": "echo \"No tests yet\" && exit 0",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "shx": "^0.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
